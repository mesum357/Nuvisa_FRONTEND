# Copy to .env.local (local dev only).
# On Render/production: set NEXT_PUBLIC_API_URL and BACKEND_API_URL to your live NestJS URL in the dashboard.
# Do NOT use localhost — NEXT_PUBLIC_* is baked into the client bundle at build time.

NEXT_PUBLIC_API_URL=http://localhost:4000
BACKEND_API_URL=http://localhost:4000
APP_ENV=development
NEXTAUTH_URL=http://localhost:3002

# Local Nuvisa-Admin — must match where you edit CMS content (default port 3001)
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3001
ADMIN_PUBLIC_URL=http://localhost:3001

MINDEE_API_KEY=
NEXT_PUBLIC_VISA_API_SERVER=https://api.qa.stampmyvisa.com
NEXT_PUBLIC_CLIENT_ID=

# Must match backend STRIPE_SECRET_KEY mode (both test or both live)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# SENDGRID_API_KEY=
# SENDGRID_FROM=no-reply@nuvisa.com

# Same Supabase Postgres as Nuvisa-Admin — copy DATABASE_URL from Nuvisa-Admin/.env.local
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
