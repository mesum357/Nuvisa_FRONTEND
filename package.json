{
  "name": "visa-app",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "prisma generate && next build",
    "build:migrate": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "check-setup": "node check-setup.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "perf:benchmark": "node scripts/perf-benchmark.mjs",
    "images:optimize": "node scripts/optimize-marketing-images.mjs",
    "verify:fixes": "node ../scripts/verify-all-fixes.mjs",
    "verify:fixes:live": "node ../scripts/verify-all-fixes.mjs --site http://localhost:3002 --admin http://localhost:3001 --backend http://localhost:4000",
    "test:post-payment": "node --test scripts/post-payment-fix.test.mjs",
    "verify:post-payment": "node ../scripts/verify-post-payment-fix.mjs --site https://staging.nuvisa.co.uk"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@sendgrid/mail": "^8.1.5",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.5.3",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.3",
    "formidable": "^3.5.4",
    "framer-motion": "^12.36.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.536.0",
    "mindee": "^4.29.0-rc5",
    "mrz": "^4.2.1",
    "next": "^16.0.7",
    "postcss": "^8.5.8",
    "prisma": "^6.2.1",
    "react": "19.1.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "19.1.0",
    "react-feather": "^2.0.10",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-use": "^17.6.0",
    "redux-persist": "^6.0.0",
    "styled-jsx": "^5.1.7",
    "sweetalert2": "^11.22.3",
    "tesseract.js": "^6.0.1",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "24.5.2",
    "@types/react": "19.1.13",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0"
  },
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": "20.x"
  }
}
