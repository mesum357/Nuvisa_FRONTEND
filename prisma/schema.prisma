generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING_VERIFICATION
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPOINTMENT_BOOKED
  AT_EMBASSY
  APPROVED
  REJECTED
  COMPLETED
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ADMIN)
  roleId    String?
  customRole AdminRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  activityLogs  ActivityLog[]

  @@index([email])
  @@index([isActive])
  @@map("admins")
}

/// Represents a custom admin role containing per-module permissions.
model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  // JSON object mapping module identifiers to permission objects, e.g.
  // { "applications": { "read": true, "write": false }, "users": { ... } }
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins      Admin[]

  @@map("admin_roles")
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  name            String
  phone           String?
  status          UserStatus @default(PENDING_VERIFICATION)
  isVerified      Boolean    @default(false)
  verifiedAt      DateTime?
  emailVerified   Boolean    @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  applications Application[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([isVerified])
  @@map("users")
}

model Application {
  id              String            @id @default(uuid())
  userId          String
  applicationNo   String            @unique
  status          ApplicationStatus @default(PENDING)
  totalAmount     Decimal           @default(0) @db.Decimal(10, 2)
  paidAmount      Decimal           @default(0) @db.Decimal(10, 2)
  appointmentDate DateTime?
  appointmentSlot String?
  submittedAt     DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents       Document[]
  comments        ApplicationComment[]
  statusHistory   ApplicationStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@index([applicationNo])
  @@map("applications")
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  documentType  String
  fileName      String
  fileUrl       String
  fileSize      Int
  uploadedAt    DateTime @default(now())
  isVerified    Boolean  @default(false)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model ApplicationComment {
  id            String   @id @default(uuid())
  applicationId String
  comment       String   @db.Text
  isInternal    Boolean  @default(false)
  createdBy     String
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_comments")
}

model ApplicationStatusHistory {
  id            String            @id @default(uuid())
  applicationId String
  oldStatus     ApplicationStatus
  newStatus     ApplicationStatus
  changedBy     String
  note          String?
  changedAt     DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_status_history")
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text")
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("site_content")
}

model AppointmentSlot {
  id          String   @id @default(uuid())
  date        DateTime
  slot        String
  maxCapacity Int      @default(10)
  booked      Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, slot])
  @@map("appointment_slots")
}

model Notification {
  id        String   @id @default(uuid())
  adminId   String?
  type      String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model ActivityLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  entity      String
  entityId    String?
  description String   @db.Text
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model SystemStats {
  id                String   @id @default(uuid())
  date              DateTime @unique
  totalApplications Int      @default(0)
  totalUsers        Int      @default(0)
  totalRevenue      Decimal  @default(0) @db.Decimal(12, 2)
  pendingApps       Int      @default(0)
  approvedApps      Int      @default(0)
  rejectedApps      Int      @default(0)

  @@map("system_stats")
}

model AppointmentText {
  id             String   @id @default(uuid())
  countryName    String   @unique
  appointmentText String  @default("Appointment in 10 days or less")
  sectionTitle   String   @default("Choose Your Country")
  sectionDescription String @default("We support 20 countries over all the visa centres in the UK")
  image          String?  // Path to country image
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  updatedBy      String?

  @@map("appointment_texts")
}

model FAQ {
  id          String   @id @default(uuid())
  question    String   @db.Text
  answer      String   @db.Text
  category    String?  // Optional category for grouping FAQs
  order       Int      @default(0) // For custom ordering
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([category])
  @@index([isActive])
  @@index([order])
  @@map("faqs")
}

/** Occasion / Everyday Steals section — shared with nuvisa-admin (TailAdmin). */
model OccasionContent {
  id          String   @id @default("current")
  title       String   @default("")
  description String   @default("")
  occasions   Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("occasion_content")
}

model ComparisonSection {
  id                String   @id @default(uuid())
  title             String   @default("Travel Agency")
  leftSideTitle     String   @default("Traditional Agency")
  rightSideTitle    String   @default("NUvisa")
  leftSideImage     String?  // URL to left side image
  rightSideImage    String?  // URL to right side image
  leftSideItems     Json     // Array of comparison items for left side
  rightSideItems    Json     // Array of comparison items for right side
  detailSections    Json?    // Array of { title: string, items: string[] }
  experienceType    String?  @default("IMAGES") // IMAGES or TASKS
  experienceItems   Json?    // For TASKS: string[], for IMAGES: { leftImage: string, rightImage: string }
  comparisonColumns Json?    // Array of column titles: string[]
  comparisonRows    Json?    // Array of { feature: string, values: string[], tooltip?: string }
  tooltip           String?
  experienceTitle   String?  @default("THE EXPERIENCE")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?
  countryName       String?

  @@map("comparison_sections")
}

model HeaderContent {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  type              String   @default("text") // text, url, email, phone
  section           String   // banner, navigation, contact, etc.
  isActive          Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("header_content")
}

model FooterContent {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  type              String   @default("text") // text, url, email, phone
  section           String   // social, links, company_info, etc.
  isActive          Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("footer_content")
}

model HeroContent {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  type              String   @default("text") // text, url, email, phone
  section           String   // title, description, cta, etc.
  isActive          Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("hero_content")
}

model KlarnaContent {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  type              String   @default("text") // text, number, currency
  section           String   // heading, subtitle, details
  isActive          Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("klarna_content")
}

model ProcessContent {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  type              String   @default("text") // text, image_url
  section           String   // heading, description, step_title, step_description
  isActive          Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("process_content")
}

model SliderContent {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text") // text, number, json
  section   String   // badges, embassy_note, urgent_note, counters, slots, banner
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("slider_content")
}

model EmailTemplate {
  id                String   @id @default(uuid())
  key               String   @unique // unique identifier for the template (e.g., "status_update", "otp_email")
  name              String   // user-friendly name
  subject           String   @db.Text // email subject with variable placeholders
  body              String   @db.Text // email body HTML with variable placeholders
  description       String?  // optional description
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@index([key])
  @@index([isActive])
  @@map("email_templates")
}

model userAccount {
  id               String   @id @default(uuid())
  phone            String   @unique
  uk_status        String?
  schengen_refused String?
  journey_purpose  String?
  dynamicAnswers   Json?
  joined           DateTime @default(now())

  @@map("user_accounts") 
}

enum QuestionType {
  TEXT
  OPTIONS
}

model PopupQuestion {
  id             String       @id @default(uuid())
  text           String
  type           QuestionType
  options        String[]
  order          Int          @default(0)
  popupContentId String
  popupContent   PopupContent @relation(fields: [popupContentId], references: [id], onDelete: Cascade)

  @@map("popup_questions")
}

model PopupContent {
  id                     String   @id @default("current")
  mainHeading            String   @default("❤️ NEW CUSTOMER OFFER - £129 fee for your first visa")
  subHeading             String   @default("Auto-booking appointment")
  offerPrice             String   @default("£129")
  originalPrice          String   @default("£100")
  continueButtonText     String   @default("Continue")
  lastQuestionButtonText String   @default("Check Required Documents")
  imageUrl               String   @default("/image/popupnew.png")
  conciergeTitle         String   @default("Concierge Assistance")
  conciergePrice         String   @default("£35")
  conciergeOfferPrice    String   @default("Free")
  lastChanceText         String   @default("Last chance (ends soon) Until {month} {year}!")
  updatedAt              DateTime @updatedAt
  questions              PopupQuestion[]

  @@map("popup_content")
}

model RecommendedSection {
  id          String   @id @default(uuid())
  title       String   @default("Recommended for you")
  description String?
  cards       Json     // Array of { title: string, description: string, image: string }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("recommended_sections")
}